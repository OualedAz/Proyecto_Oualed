{
  "outputDirectory": "frontend",
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "proyectooualed-production.up.railway.app"
    },
    {
      "source": "/uploads/:path*",
      "destination": "proyectooualed-production.up.railway.app"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
